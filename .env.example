# Publiczny URL witryny (linki w mailach, m.in. galeria po opłaceniu). Np. https://jakubsztuba.pl
# NEXT_PUBLIC_SITE_URL=

# Panel admina — podgląd maili /admin/email oraz galeria /admin/foto-galeria (?key=…)
# ADMIN_EMAIL_PREVIEW_SECRET=

# Supabase — zapis wypełnień formularza (tabela foto_rozliczenia).
# Migracje: supabase/migrations/20260215120000_foto_galeria_paid_download.sql
# oraz 20260215140000_foto_admin_submitted_notes_photo.sql
# Bucket Storage (publiczny odczyt): foto_rozliczenia_admin — upload zdjęć w panelu admina.
# URL: Project Settings → API → Project URL
SUPABASE_URL=
# service_role (sekret, tylko serwer — nigdy w przeglądarce)
SUPABASE_SERVICE_ROLE_KEY=

# inFakt (wymagane do płatności)
INFAKT_API_KEY=

# Webhook inFakt (HMAC w nagłówku X-Infakt-Signature) — sekret z ustawień webhooka
# URL aplikacji: POST /api/webhooks/infakt — zdarzenie invoice_paid → mail z linkiem do galerii (24h)
# Diagnostyka (GET, bez sekretów): otwórz w przeglądarce /api/webhooks/infakt na produkcji
# INFAKT_WEBHOOK_SECRET=

# Opcjonalnie: sandbox — https://api.sandbox-infakt.pl/v3
# INFAKT_API_BASE_URL=https://api.infakt.pl/v3

# Nazwa pozycji na fakturze i daty sprzedaży są ustalane w kodzie (inFakt).

# Mailjet — maile transakcyjne (Send API v3.1)
# https://app.mailjet.com/account/api_keys
MAILJET_API_KEY=
MAILJET_API_SECRET=
# Nadawca musi być zweryfikowaną domeną / adresem w Mailjet
MAILJET_FROM_EMAIL=
# MAILJET_FROM_NAME=Jakub Sztuba

# Webhook Event API — tajny token w URL: /api/mailjet/events?token=...
# https://dev.mailjet.com/email/guides/#event-api-real-time-notifications
MAILJET_WEBHOOK_SECRET=
